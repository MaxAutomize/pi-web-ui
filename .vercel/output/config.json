{
  "version": 3,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?$",
      "dest": "/server.js?path=$1",
      "check": true
    },
    {
      "handle": "error"
    },
    {
      "status": 404,
      "src": "^(?!/api).*$",
      "dest": "/404.html"
    }
  ],
  "framework": {
    "version": "4.22.2"
  },
  "crons": []
}
